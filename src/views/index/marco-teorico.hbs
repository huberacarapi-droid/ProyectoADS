</div>

          <div class="table-responsive">
            <table class="table table-bordered table-hover table-striped">
              <thead class="thead-dark">
                <tr>
                  <th>Indicador</th>
                  <th>Resultado</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Participación actual (votó en las últimas elecciones)</td>
                  <td>17.7%</td>
                </tr>
                <tr>
                  <td>No votantes por falta de tiempo o urnas lejanas</td>
                  <td>34.9%</td>
                </tr>
                <tr>
                  <td>No votantes por desconfianza en el proceso</td>
                  <td>29.9%</td>
                </tr>
