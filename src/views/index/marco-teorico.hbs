      <!-- ====================================== -->

      <div id="resultados" class="card shadow-lg border-0 mb-4">

        <div class="card-header bg-secondary text-white">

          <h3 class="mb-0">
            6. Resultados de la Encuesta
          </h3>

        </div>

        <div class="card-body">

          <p align="justify">
            Con el propósito de identificar las principales necesidades, percepciones y expectativas de los estudiantes
            respecto al proceso electoral universitario, se aplicó una encuesta a una muestra representativa de 300
            estudiantes de la Universidad Mayor de San Andrés. Los resultados obtenidos permitieron identificar
            problemas relevantes del sistema actual y determinar las características más demandadas para una propuesta
            de votación electrónica.
          </p>

          <div class="row text-center my-4">

  <div class="col-md-6 mb-3">

    <img src="/img/encuesta1.png"
