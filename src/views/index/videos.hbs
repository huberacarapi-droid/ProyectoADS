{{> index/header}}

<!-- ====================================== -->
<!-- BREADCRUMB -->
<!-- ====================================== -->

<div class="container-fluid">

    <ol class="breadcrumb shadow-sm">

        <li class="breadcrumb-item">
            <a href="/">
                <i class="fa fa-fw fa-home"></i>
                Inicio
            </a>
        </li>

        <li class="breadcrumb-item active">
            <i class="fa fa-fw fa-video-camera"></i>
            Videos Educativos
        </li>

    </ol>

</div>

<!-- ====================================== -->
<!-- BODY PRINCIPAL -->
<!-- ====================================== -->

<main class="container-fluid mt-4">

    <!-- ====================================== -->
    <!-- HERO -->
    <!-- ====================================== -->

    <div class="row mb-4">

        <div class="col-12">

            <div class="jumbotron shadow-lg text-white hero-panel">

                <div class="row align-items-center">

                    <div class="col-md-8">

                        <h1 class="display-4 font-weight-bold">
                            Contenido Multimedia
                        </h1>

                        <p class="lead mt-4">
                            Recursos audiovisuales para el aprendizaje
                            del modelado de software y el funcionamiento
                            del Sistema de Votación Virtual UMSA.
                        </p>

                        <hr class="bg-white">

                        <p>
                            Explora tutoriales prácticos, descripciones detalladas
                            y guías interactivas diseñadas para fortalecer
                            tus conocimientos en ingeniería de software.
                        </p>

                    </div>

                    <div class="col-md-4 text-center">

                        <i class="fa fa-video-camera hero-icon"></i>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- ====================================== -->
    <!-- CONTENIDO -->
    <!-- ====================================== -->

    <div class="row">

        <!-- ====================================== -->
        <!-- SIDEBAR -->
        <!-- ====================================== -->

        <div class="col-lg-3 mb-4">

            <div class="card shadow border-0 sticky-top">

                <div class="card-header bg-primary text-white">

                    <h5 class="mb-0">
                        <i class="fa fa-list"></i>
                        Navegación Rápida
                    </h5>

                </div>

                <div class="card-body sidebar-menu">

                    <div class="mb-4">

                        <h6 class="sidebar-title">
                            <i class="fa fa-play-circle-o"></i>
                            LISTA DE VIDEOS
                        </h6>

                        <ul class="list-group">

                            <a href="#video-modelado" class="list-group-item list-group-item-action">
                                Manejo del Software de Modelado
                            </a>

                            <a href="#video-sistema" class="list-group-item list-group-item-action">
                                Descripción del Sistema
                            </a>

                            <a href="#video-votacion" class="list-group-item list-group-item-action">
                                Manejo del Sistema de Votación Virtual UMSA
                            </a>

                        </ul>

                    </div>

                </div>

            </div>

        </div>

        <!-- ====================================== -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ====================================== -->

        <div class="col-lg-9">

            <!-- ====================================== -->
            <!-- VIDEO 1: MODELADO -->
            <!-- ====================================== -->

            <div id="video-modelado" class="card shadow-lg border-0 mb-4">

                <div class="card-header bg-white">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <h3 class="mb-0 font-weight-bold text-primary">
                                Manejo del Software de Modelado
                            </h3>

                            <small class="text-muted">
                                Tutorial práctico • Herramientas UML
                            </small>

                        </div>

                        <span class="badge badge-primary p-2">

                            <i class="fa fa-youtube-play"></i>
                            Video 1

                        </span>

                    </div>

                </div>

                <div class="card-body">

                    <div class="alert alert-info">

                        <h5>
                            <i class="fa fa-info-circle"></i>
                            Descripción
                        </h5>

                        <p class="mb-0">
                            Aprende a utilizar las principales herramientas de software
                            para modelado UML. Este video guía paso a paso
                            la creación de diagramas de casos de uso,
                            clases y secuencia, aplicados a proyectos reales
                            de ingeniería de software.
                        </p>

                    </div>

                    <div class="text-center mt-4 mb-4">

                        <div class="embed-responsive embed-responsive-16by9 shadow rounded">

                            <!-- ENLACE DE YOUTUBE: Manejo del software de modelado -->
                            <iframe class="embed-responsive-item"
                                    src="https://www.youtube.com/embed/yUHesW2JAug"
                                    title="Manejo del software de modelado"
                                    frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen>
                            </iframe>

                        </div>

                        <p class="mt-2 text-muted">
                            Haz clic en el video para ver el tutorial completo.
                        </p>

                    </div>

                </div>

            </div>

            <!-- ====================================== -->
            <!-- VIDEO 2: DESCRIPCIÓN DEL SISTEMA -->
            <!-- ====================================== -->

            <div id="video-sistema" class="card shadow-lg border-0 mb-4">

                <div class="card-header bg-white">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <h3 class="mb-0 font-weight-bold text-success">
                                Descripción del Sistema
                            </h3>

                            <small class="text-muted">
                                Arquitectura y funcionalidades generales
                            </small>

                        </div>

                        <span class="badge badge-success p-2">

                            <i class="fa fa-youtube-play"></i>
                            Video 2

                        </span>

                    </div>

                </div>

                <div class="card-body">

                    <div class="alert alert-success">

                        <h5>
                            <i class="fa fa-info-circle"></i>
                            Descripción
                        </h5>

                        <p class="mb-0">
                            Conoce la visión general del Sistema de Votación Virtual UMSA.
                            Se explican los módulos principales,
                            la infraestructura tecnológica,
                            los actores involucrados y el flujo completo
                            de una votación electrónica universitaria.
                        </p>

                    </div>

                    <div class="text-center mt-4 mb-4">

                        <div class="embed-responsive embed-responsive-16by9 shadow rounded">

                            <!-- ENLACE DE YOUTUBE: Descripción del sistema -->
                            <iframe class="embed-responsive-item"
                                    src="https://www.youtube.com/embed/tg8HRCQY0Zc"
                                    title="Descripción del Sistema de Votación Virtual UMSA"
                                    frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen>
                            </iframe>

                        </div>

                        <p class="mt-2 text-muted">
                            Haz clic en el video para ver la descripción completa.
                        </p>

                    </div>

                </div>

            </div>

            <!-- ====================================== -->
            <!-- VIDEO 3: MANEJO DEL SISTEMA DE VOTACIÓN -->
            <!-- ====================================== -->

            <div id="video-votacion" class="card shadow-lg border-0 mb-4">

                <div class="card-header bg-white">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <h3 class="mb-0 font-weight-bold text-warning">
                                Manejo del Sistema de Votación Virtual UMSA
                            </h3>

                            <small class="text-muted">
                                Guía de usuario • Demostración interactiva
                            </small>

                        </div>

                        <span class="badge badge-warning p-2">

                            <i class="fa fa-youtube-play"></i>
                            Video 3

                        </span>

                    </div>

                </div>

                <div class="card-body">

                    <div class="alert alert-warning">

                        <h5>
                            <i class="fa fa-info-circle"></i>
                            Descripción
                        </h5>

                        <p class="mb-0">
                            Tutorial completo para votantes y administradores.
                            Aprende a autenticarte, emitir tu voto,
                            consultar resultados y gestionar procesos electorales
                            dentro de la plataforma VIRTUAL UMSA.
                        </p>

                    </div>

                    <div class="text-center mt-4 mb-4">

                        <div class="embed-responsive embed-responsive-16by9 shadow rounded">

                            <!-- ENLACE DE YOUTUBE: Manejo del sistema de votación VIRTUAL UMSA -->
                            <iframe class="embed-responsive-item"
                                    src="https://www.youtube.com/embed/lJS_VQdA_Ag"
                                    title="Manejo del Sistema de Votación Virtual UMSA"
                                    frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen>
                            </iframe>

                        </div>

                        <p class="mt-2 text-muted">
                            Haz clic en el video para ver el manejo práctico del sistema.
                        </p>

                    </div>

<div class="text-center mt-4 mb-4">

                        <div class="embed-responsive embed-responsive-16by9 shadow rounded">

                            <!-- ENLACE DE YOUTUBE: Manejo del sistema de votación VIRTUAL UMSA -->
                            <iframe class="embed-responsive-item"
                                    src="https://www.youtube.com/embed/f-OF2GQJTaY"
                                    title="Manejo del Sistema de Votación Virtual UMSA"
                                    frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen>
                            </iframe>

                        </div>

                        <p class="mt-2 text-muted">
                            Haz clic en el video para ver el manejo práctico del sistema.
                        </p>

                    </div>
                </div>

            </div>

        </div>

    </div>

</main>

<!-- ====================================== -->
<!-- ESTILOS -->
<!-- ====================================== -->

<style>

    html{
        scroll-behavior: smooth;
    }

    .hero-panel{
        background: linear-gradient(135deg,#003b75,#0056b3);
        border-radius: 15px;
    }

    .hero-icon{
        font-size: 9rem;
        opacity: 0.2;
    }

    .sidebar-title{
        font-weight: bold;
        margin-bottom: 15px;
    }

    .sidebar-menu .list-group-item{
        border: none;
        border-left: 4px solid transparent;
        transition: 0.3s;
        font-size: 14px;
    }

    .sidebar-menu .list-group-item:hover{
        background: #f1f7ff;
        border-left: 4px solid #007bff;
        padding-left: 25px;
    }

    .card{
        border-radius: 12px;
    }

    .sticky-top{
        top: 20px;
    }

    .embed-responsive {
        border-radius: 12px;
        overflow: hidden;
    }

</style>

{{> index/footer}}