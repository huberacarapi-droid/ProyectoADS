{{> index/header}}

<!-- ====================================== -->
<!-- BREADCRUMB -->
<!-- ====================================== -->

<div class="container-fluid">

  <ol class="breadcrumb shadow-sm">

    <li class="breadcrumb-item">
      <a href="/">
        <i class="fa fa-fw fa-home"></i>
        Inicio
      </a>
    </li>

    <li class="breadcrumb-item active">
      <i class="fa fa-fw fa-random"></i>
      Análisis Estructurado
    </li>

  </ol>

</div>


<!-- ====================================== -->
<!-- BODY PRINCIPAL -->
<!-- ====================================== -->

<main class="container-fluid mt-4">

  <!-- ====================================== -->
  <!-- HERO -->
  <!-- ====================================== -->

  <div class="row mb-4">

    <div class="col-12">

      <div class="jumbotron shadow-lg text-white hero-panel">

        <div class="row align-items-center">

          <div class="col-md-8">

            <h1 class="display-4 font-weight-bold">
              ANÁLISIS ESTRUCTURADO
            </h1>

            <p class="lead mt-4">
              Modelado y documentación del Sistema de Votación Virtual UMSA
              mediante técnicas de análisis estructurado para la identificación
              de procesos, actores, eventos y flujos de información.
            </p>

            <hr class="bg-white">

            <p>
              Esta sección presenta el Modelo Ambiental y el Modelo de
              Comportamiento, utilizados para comprender el entorno del sistema,
              sus interacciones y el funcionamiento de los procesos electorales
              universitarios.
            </p>

          </div>

          <div class="col-md-4 text-center">

            <i class="fa fa-book hero-icon"></i>

          </div>

        </div>

      </div>

    </div>

  </div>

  <!-- ====================================== -->
  <!-- CONTENIDO -->
  <!-- ====================================== -->

  <div class="row">

    <!-- ====================================== -->
    <!-- SIDEBAR -->
    <!-- ====================================== -->

    <div class="col-lg-3 mb-4">

      <div class="card shadow border-0 sticky-top">

        <div class="card-header bg-primary text-white">

          <h5 class="mb-0">
            <i class="fa fa-list"></i>
            Navegación
          </h5>

        </div>

        <div class="card-body sidebar-menu">

          <div class="mb-4">

            <h6 class="sidebar-title">
              <i class="fa fa-home"></i>
              <a href="/" style="color: #003b75; text-decoration: none;">
                INICIO
            </h6>
          </div>

          <div class="mb-4">

            <h6 class="sidebar-title">
              <i class="fa fa-book"></i>
              <a href="/analisis-estructurado" style="color: #003b75; text-decoration: none;">
                ANÁLISIS ESTRUCTURADO
              </a>
            </h6>

            <ul class="list-group">

              <a href="/analisis-estructurado/modelo-ambiental" class="list-group-item list-group-item-action">
                1. Modelo Ambiental
              </a>

              <a href="/analisis-estructurado/modelo-comportamiento" class="list-group-item list-group-item-action">
                2. Modelo de Comportamiento
              </a>

            </ul>

          </div>

        </div>

      </div>

    </div>

    <!-- ====================================== -->
    <!-- CONTENIDO -->
    <!-- ====================================== -->

    <div class="col-lg-9">

      <div class="card shadow-lg border-0 mb-4">

        <div class="card-header bg-primary text-white">

          <h3 class="mb-0">
            Análisis Estructurado
          </h3>

        </div>

        <div class="card-body">

          <p align="justify">
            El análisis estructurado es una metodología utilizada para estudiar,
            modelar y documentar sistemas de información mediante diagramas y
            modelos que representan el entorno, los procesos y el flujo de datos.
          </p>

          <p align="justify">
            En el Sistema de Votación Virtual UMSA, el análisis estructurado
            permite identificar los actores involucrados, los procesos electorales,
            los flujos de información y las reglas de negocio necesarias para el
            funcionamiento de la plataforma.
          </p>

          <p align="justify">
            Esta sección contiene los modelos desarrollados durante la etapa de
            análisis del sistema, los cuales sirven como base para el diseño e
            implementación de la solución propuesta.
          </p>

        </div>

      </div>

      <div class="row">

        <!-- MODELO AMBIENTAL -->

        <div class="col-md-6 mb-4">

          <div class="card shadow border-0 h-100">

            <div class="card-body text-center">

              <i class="fa fa-globe fa-4x text-primary mb-3"></i>

              <h4>
                Modelo Ambiental
              </h4>

              <p align="justify">
                Describe el entorno del sistema, identificando los actores,
                eventos y relaciones externas que interactúan con el Sistema
                de Votación Virtual UMSA.
              </p>

              <a href="/analisis-estructurado/modelo-ambiental" class="btn btn-primary">
                Ver Modelo Ambiental
              </a>

            </div>

          </div>

        </div>

        <!-- MODELO DE COMPORTAMIENTO -->

        <div class="col-md-6 mb-4">

          <div class="card shadow border-0 h-100">

            <div class="card-body text-center">

              <i class="fa fa-random fa-4x text-success mb-3"></i>

              <h4>
                Modelo de Comportamiento
              </h4>

              <p align="justify">
                Representa la dinámica del sistema mediante procesos,
                transformaciones y flujos de datos que permiten ejecutar
                las funciones del proceso electoral.
              </p>

              <a href="/analisis-estructurado/modelo-comportamiento" class="btn btn-success">
                Ver Modelo de Comportamiento
              </a>

            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

</main>

