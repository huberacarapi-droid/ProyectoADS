<main>
    <!-- ====================================== -->
    <!-- BREADCRUMB -->
    <!-- ====================================== -->

    <div class="container-fluid">

        <ol class="breadcrumb shadow-sm">

            <li class="breadcrumb-item">

                <a href="/inicio">

                    <i class="fa fa-fw fa-home"></i>
                    Inicio

                </a>

            </li>

            <li class="breadcrumb-item active">

                <i class="fa fa-fw fa-cube"></i>
                Elecciones

            </li>

        </ol>

    </div>
    <!-- ====================================== -->
    <!-- HERO -->
    <!-- ====================================== -->

    <section class="hero-election py-5 mb-4">

        <div class="container">

            <div class="row align-items-center">

                <div class="col-lg-8 text-white">

                    <h1 class="display-4 font-weight-bold">

                        <i class="fa fa-cube"></i>
                        Elecciones Universitarias UMSA

                    </h1>

                    <p class="lead mt-3">

                        Participa en los procesos democráticos virtuales
                        de la Universidad Mayor de San Andrés.

                    </p>

                    <p>

                        Consulta elecciones activas, revisa candidatos,
                        emite tu voto de forma segura y visualiza resultados
                        oficiales en tiempo real.

                    </p>

                </div>

                <div class="col-lg-4 text-center">

                    <img src="/svg/iconos/elecciones.svg"
                        alt="Elecciones"
                        class="hero-img">

                </div>

            </div>

        </div>

    </section>



    <!-- ====================================== -->
    <!-- CONTENIDO -->
    <!-- ====================================== -->

    <div class="container">

        <!-- ====================================== -->
        <!-- TITULO -->
        <!-- ====================================== -->

        <div class="row mb-4">

            <div class="col-md-12">

                <div class="card border-0 shadow-sm">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center flex-wrap">

                            <div>

                                <h2 class="font-weight-bold text-primary mb-2">

                                    Procesos Electorales Disponibles

                                </h2>

                                <p class="text-muted mb-0">

                                    Seleccione una elección para participar
                                    o consultar los resultados oficiales.

                                </p>

                            </div>

                            <span class="badge badge-primary p-3">

                                <i class="fa fa-university"></i>
                                UMSA Virtual

                            </span>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- ====================================== -->
        <!-- ACORDEON -->
        <!-- ====================================== -->

        <div class="accordion"
            id="accordionElecciones">

            {{#each ejecutadas}}

            <div class="card election-card shadow-lg border-0 mb-4">

                <!-- HEADER -->

                <div class="card-header election-header"
                    id="heading{{id}}">

                    <h2 class="mb-0">

                        <button class="btn btn-link btn-block text-left election-button"
                            type="button"
                            data-toggle="collapse"
                            data-target="#collapse{{id}}"
                            aria-expanded="true"
                            aria-controls="collapse{{id}}">

                            <div class="d-flex justify-content-between align-items-center flex-wrap">

                                <div>

                                    <i class="fa fa-fw fa-gavel mr-2"></i>

                                    {{titulo}}

                                </div>

                                <span class="badge badge-light">

                                    <i class="fa fa-clock-o"></i>
                                    Activa

                                </span>

                            </div>

                        </button>

                    </h2>

                </div>

                <!-- BODY -->

                <div id="collapse{{id}}"
                    class="collapse show"
                    aria-labelledby="heading{{id}}"
                    data-parent="#accordionElecciones">

                    <div class="card-body">

                        <div class="row align-items-center">

                            <!-- INFORMACION -->

                            <div class="col-lg-8">

                                <h3 class="display-6 font-weight-bold text-primary">

                                    {{titulo}}

                                </h3>

                                <p class="lead text-secondary">

                                    {{descripcion}}

                                </p>

                                <div class="alert alert-light border">

                                    <i class="fa fa-info-circle text-primary"></i>

                                    Última actualización:
                                    <strong>{{timeago updatedAt}}</strong>

                                </div>

                            </div>

                            <!-- ICONO -->

                            <div class="col-lg-4 text-center">

                                <div class="election-icon-circle">

                                    <i class="fa fa-check-square-o"></i>

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- FOOTER -->

                    <div class="card-footer bg-white border-0 pb-4">

                        <div class="row">

                            <div class="col-md-6 mb-2">

                                <a href="/inicio/elecciones/voto/{{id}}"
                                    class="btn btn-primary btn-lg btn-block">

                                    <i class="fa fa-fw fa-pencil-square-o"></i>
                                    Emitir Voto

                                </a>

                            </div>

                            <div class="col-md-6 mb-2">

                                <a href="/inicio/elecciones/resultado/{{id}}"
                                    class="btn btn-outline-dark btn-lg btn-block">

                                    <i class="fa fa-fw fa-bar-chart"></i>
                                    Ver Resultados

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            {{/each}}

        </div>

    </div>

</main>

<!-- ====================================== -->
<!-- ESTILOS -->
<!-- ====================================== -->

<style>

    body{
        background:#f4f6f9;
    }

    /* ====================================== */
    /* HERO */
    /* ====================================== */

    .hero-election{
        background:linear-gradient(135deg,#003b75,#0056b3);
        border-bottom:5px solid #f4b400;
    }

    .hero-img{
        width:220px;
        filter:drop-shadow(0 10px 25px rgba(0,0,0,0.25));
    }

    /* ====================================== */
    /* BREADCRUMB */
    /* ====================================== */

    .breadcrumb{
        background:white;
        border-radius:12px;
        padding:15px 20px;
    }

    .breadcrumb a{
        color:#003b75;
        font-weight:500;
        text-decoration:none;
    }

    /* ====================================== */
    /* CARD */
    /* ====================================== */

    .election-card{
        border-radius:18px;
        overflow:hidden;
        transition:0.3s;
    }

    .election-card:hover{
        transform:translateY(-5px);
    }

    .election-header{
        background:linear-gradient(90deg,#003b75,#0056b3);
        border:none;
    }

    .election-button{
        color:white !important;
        font-size:1.1rem;
        font-weight:bold;
        text-decoration:none !important;
    }

    .election-button:hover{
        text-decoration:none !important;
        color:#f4b400 !important;
    }

    /* ====================================== */
    /* ICONO */
    /* ====================================== */

    .election-icon-circle{
        width:140px;
        height:140px;
        border-radius:50%;
        background:rgba(0,123,255,0.1);
        display:flex;
        justify-content:center;
        align-items:center;
        margin:auto;
    }

    .election-icon-circle i{
        font-size:70px;
        color:#003b75;
    }

    /* ====================================== */
    /* BOTONES */
    /* ====================================== */

    .btn-primary{
        background:#003b75;
        border:none;
        border-radius:10px;
        padding:12px;
        font-weight:bold;
    }

    .btn-primary:hover{
        background:#0056b3;
    }

    .btn-outline-dark{
        border-radius:10px;
        font-weight:bold;
    }

    /* ====================================== */
    /* BADGES */
    /* ====================================== */

    .badge-light{
        font-size:13px;
        padding:10px 14px;
    }

</style>