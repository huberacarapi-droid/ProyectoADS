<script src="/js/colorpicker.js"></script>

<script>
    const dropZone = document.getElementById('dropZone');
    const imageInput = document.getElementById('imageInput');
    const selectedImage = document.getElementById('selectedImage');

    dropZone.addEventListener('click', () => {
        imageInput.click();
    });

    imageInput.addEventListener('change', function () {
        previewImage(this.files[0]);
    });

    dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
    });

    dropZone.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
    });

    dropZone.addEventListener('drop', (e) => {
        e.preventDefault();

        dropZone.classList.remove('dragover');

        const file = e.dataTransfer.files[0];

        if (file) {
            imageInput.files = e.dataTransfer.files;
            previewImage(file);
        }
    });

    function previewImage(file) {

        if (!file.type.startsWith('image/')) {

            Swal.fire({
                icon: 'warning',
                title: 'Archivo inválido',
                text: 'Seleccione una imagen válida'
            });

            return;
        }

        if (file.size > 2 * 1024 * 1024) {

            Swal.fire({
                icon: 'warning',
                title: 'Imagen demasiado grande',
                text: 'La imagen no debe superar 2MB'
            });

            return;
        }

        const reader = new FileReader();

        reader.onload = function (e) {

            selectedImage.src = e.target.result;

            selectedImage.classList.remove('d-none');
        }

        reader.readAsDataURL(file);
    }

    const colorInput = document.getElementById('colorInput');
    const colorDisplay = document.getElementById('colorDisplay');
    const selectedColorHex = document.getElementById('selectedColorHex');

    colorInput.addEventListener('input', function () {

        colorDisplay.style.backgroundColor = this.value;

        selectedColorHex.textContent = this.value;
    });

    $('form').submit(function (e) {

        const sigla = $('#sigla').val().trim();
        const descripcion = $('#descripcion').val().trim();

        if (sigla.length < 2) {

            e.preventDefault();

            Swal.fire({
                icon: 'warning',
                title: 'Sigla inválida',
                text: 'Ingrese una sigla válida'
            });

            return;
        }

        if (descripcion.length < 5) {

            e.preventDefault();

            Swal.fire({
                icon: 'warning',
                title: 'Descripción inválida',
                text: 'Ingrese una descripción válida'
            });

            return;
        }

        Swal.fire({
            title: 'Guardando cambios...',
            text: 'Espere un momento',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });
    });
</script>
