<style>

    :root{
        --primary:#003b75;
        --primary-light:#0056b3;
        --light-bg:#f4f6f9;
    }

    body{
        background:var(--light-bg);
    }

    .breadcrumb{
        background:#fff;
        border-radius:12px;
        padding:14px 20px;
        box-shadow:0 2px 10px rgba(0,0,0,.06);
    }

    .breadcrumb a{
        color:var(--primary);
        font-weight:500;
        text-decoration:none;
    }

    .page-header{
        background:linear-gradient(135deg,var(--primary),var(--primary-light));
        border-radius:20px;
        padding:35px;
        color:white;
        margin-bottom:25px;
        box-shadow:0 10px 25px rgba(0,0,0,.08);
    }

    .page-header h2{
        font-weight:bold;
    }

    .page-header p{
        opacity:.92;
    }

    .btn-return{
        border-radius:10px;
        padding:10px 20px;
        font-weight:600;
    }

    .form-card{
        background:white;
        border:none;
        border-radius:20px;
        overflow:hidden;
        box-shadow:0 10px 25px rgba(0,0,0,.06);
    }

    .form-header{
        background:linear-gradient(90deg,var(--primary),var(--primary-light));
        color:white;
        padding:20px 30px;
    }

    .form-header h4{
        margin:0;
        font-weight:bold;
    }

    .form-body{
        padding:30px;
    }

    .form-control{
        border-radius:10px;
        min-height:48px;
    }

    textarea.form-control{
        min-height:120px;
    }

    label{
        font-weight:600;
        color:#495057;
    }

    #dropZone{
        border:2px dashed #bfc8d4;
        border-radius:16px;
        background:#f8fafc;
        height:260px;
        display:flex;
        justify-content:center;
        align-items:center;
        text-align:center;
        cursor:pointer;
        transition:.3s;
        padding:20px;
    }

    #dropZone:hover{
        border-color:var(--primary);
        background:#eef5ff;
    }

    #dropZone p{
        margin:0;
        color:#6c757d;
        font-weight:600;
    }

    #imageInput{
        display:none;
    }

    #imageZone{
        border-radius:16px;
        background:#f8fafc;
        border:1px solid #dee2e6;
        height:260px;
        display:flex;
        justify-content:center;
        align-items:center;
        overflow:hidden;
    }

    #selectedImage{
        width:100%;
        height:100%;
        object-fit:contain;
    }

    .hidden{
        display:none;
    }

    #colorPalette{
        display:flex;
        flex-wrap:wrap;
        gap:12px;
        margin-top:20px;
    }

    .color-box{
        width:50px;
        height:50px;
        border-radius:12px;
        cursor:pointer;
        border:3px solid transparent;
        transition:.2s;
        box-shadow:0 2px 10px rgba(0,0,0,.08);
    }

    .color-box:hover{
        transform:scale(1.08);
    }

    .color-box.active{
        border-color:#212529;
    }

    #selectedColor{
        margin-top:10px;
        padding:20px;
        background:#f8fafc;
        border-radius:16px;
        border:1px solid #dee2e6;
    }

    #colorDisplay{
        width:120px;
        height:50px;
        border-radius:12px;
        border:1px solid #ced4da;
        margin:10px 0;
    }

    #selectedColorHex{
        font-weight:bold;
        color:#495057;
        margin:0;
    }

    .btn-save{
        background:linear-gradient(90deg,var(--primary),var(--primary-light));
        color:white;
        border:none;
        border-radius:12px;
        padding:12px 25px;
        font-weight:600;
        transition:.3s;
    }

    .btn-save:hover{
        transform:translateY(-2px);
        box-shadow:0 10px 20px rgba(0,86,179,.25);
        color:white;
    }

</style>

<main>

    <div class="container-fluid">

        <ol class="breadcrumb">

            <li class="breadcrumb-item">

                <a href="/inicio">

                    <i class="fa fa-fw fa-home"></i>
                    Inicio

                </a>

            </li>

            <li class="breadcrumb-item">

                <a href="/administrar">

                    <i class="fa fa-fw fa-cogs"></i>
                    Administrar

                </a>

            </li>

            <li class="breadcrumb-item">

                <a href="/administrar/elecciones">

                    <i class="fa fa-fw fa-cube"></i>
                    Elecciones

                </a>

            </li>

            <li class="breadcrumb-item">

                <a href="/administrar/elecciones/programar/{{eleccion.id}}">

                    <i class="fa fa-fw fa-file-text"></i>
                    Programar

                </a>

            </li>

            <li class="breadcrumb-item">

                <a href="/administrar/elecciones/programar/frentes/{{eleccion.id}}">

                    <i class="fa fa-fw fa-newspaper-o"></i>
                    Frentes

                </a>

            </li>

            <li class="breadcrumb-item active">

                <i class="fa fa-fw fa-plus-circle"></i>
                Nuevo

            </li>

        </ol>

    </div>

    <div class="container mt-4">

        <!-- HERO -->

        <div class="page-header">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>

                    <h2>

                        <i class="fa fa-fw fa-newspaper-o"></i>
                        Registro de Frentes Políticos

                    </h2>

                    <h5 class="mt-3">

                        {{eleccion.titulo}}

                    </h5>

                    <p class="mb-0">

                        {{eleccion.descripcion}}

                    </p>

                </div>

                <div>

                    <a id="back"
                        class="btn btn-light btn-return"
                        href="/administrar/elecciones/programar/frentes/{{eleccion.id}}">

                        <i class="fa fa-fw fa-undo"></i>
                        Retornar

                    </a>

                </div>

            </div>

        </div>

        <!-- FORM -->

        <div class="card form-card mb-5">

            <div class="form-header">

                <h4>

                    <i class="fa fa-fw fa-plus-circle"></i>
                    Nuevo Frente Político

                </h4>

            </div>

            <div class="form-body">

                <form action="/administrar/elecciones/programar/frentes/nuevo/{{eleccion.id}}"
                    method="POST"
                    enctype="multipart/form-data">

                    <div class="form-row">

                        <div class="form-group col-12 col-md-6">

                            <label for="sigla">

                                Sigla

                            </label>

                            <input type="text"
                                class="form-control"
                                id="sigla"
                                name="sigla"
                                placeholder="Ingrese la sigla del frente político"
                                required>

                        </div>

                        <div class="form-group col-12 col-md-6">

                            <label for="descripcion">

                                Descripción de la Sigla

                            </label>

                            <textarea class="form-control"
                                id="descripcion"
                                name="descripcion"
                                rows="3"
                                placeholder="Ingrese una descripción de la sigla"
                                required></textarea>

                        </div>

                    </div>

                    <!-- LOGO -->

                    <div class="form-group">

                        <label for="logo">

                            Logotipo del Frente Político

                        </label>

                        <div class="row">

                            <!-- DROPZONE -->

                            <div class="col-md-6 mb-3">

                                <div id="dropZone">

                                    <p>

                                        <i class="fa fa-cloud-upload fa-3x mb-3"></i>
                                        <br>

                                        Arrastre una imagen aquí
                                        <br>
                                        o haga click para seleccionar

                                    </p>

                                </div>

                                <input type="file"
                                    id="imageInput"
                                    name="logo"
                                    accept="image/*">

                            </div>

                            <!-- PREVIEW -->

                            <div class="col-md-6 mb-3">

                                <div id="imageZone">

                                    <img id="selectedImage"
                                        alt="Selected Image"
                                        class="hidden">

                                </div>

                            </div>

                        </div>

                        <!-- PALETA -->

                        <div class="row">

                            <div class="col">

                                <div id="colorPalette"></div>

                            </div>

                        </div>

                    </div>

                    <!-- COLOR -->

                    <div class="form-group">

                        <label for="color">

                            Color del Frente Político

                        </label>

                        <div id="selectedColor">

                            <p>

                                Color Seleccionado:

                            </p>

                            <div id="colorDisplay"></div>

                            <p id="selectedColorHex"></p>

                        </div>

                        <input id="colorInput"
                            type="color"
                            class="invisible"
                            name="color"
                            required>

                    </div>

                    <!-- BUTTON -->

                    <div class="form-group mb-0 mt-4">

                        <button type="submit"
                            class="btn btn-save">

                            <i class="fa fa-fw fa-floppy-o"></i>
                            Guardar Nuevo Frente

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</main>

<script src="/js/colorpicker.js"></script>