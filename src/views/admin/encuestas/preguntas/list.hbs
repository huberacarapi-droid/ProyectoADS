<main>
    <div class="container-fluid">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="/inicio">
                    <i class="fa fa-fw fa-home"></i>
                    Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/administrar">
                    <i class="fa fa-fw fa-cogs"></i>
                    Administrar
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/administrar/encuestas">
                    <i class="fa fa-fw fa-check-square-o"></i>
                    Encuestas
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/administrar/encuestas/programar/{{encuesta.id}}">
                    <i class="fa fa-fw fa-file-text-o"></i>
                    Programar
                </a>
            </li>
            <li class="breadcrumb-item active">
                <i class="fa fa-fw fa-question-circle-o"></i>
                Preguntas
            </li>
        </ol>
    </div>
    <div class="container mt-5">
        <h2>Lista de Preguntas de la Encuesta</h2>
        <h5>{{encuesta.titulo}}</h5>
        <p class="small">{{encuesta.descripcion}}</p>
        <div id="toolbar">
            <a id="add" class="btn btn-outline-primary"
                href="/administrar/encuestas/programar/preguntas/nuevo/{{encuesta.id}}">
                <i class="fa fa-fw fa-plus-circle"></i> Agregar Nueva Pregunta
            </a>
            <a id="back" class="btn btn-outline-dark ml-3" href="/administrar/encuestas/programar/{{encuesta.id}}">
                <i class="fa fa-fw fa-undo"></i> Retornar
            </a>
        </div>
        <table class="table table-condensed text-small" id="table" data-toggle="table" data-locale="es-ES"
            data-toolbar="#toolbar" data-search="true" data-advanced-search="false" data-show-refresh="false"
            data-show-toggle="true" data-show-fullscreen="true" data-show-columns="true"
            data-show-columns-toggle-all="true" data-detail-view="true" data-detail-formatter="detailFormatter"
            data-show-export="true" data-click-to-select="true" data-sortable="true" data-minimum-count-columns="2"
            data-show-pagination-switch="false" data-pagination="true" data-id-field="id"
            data-page-list="[5, 10, 15, 20, all]" data-show-footer="false" data-response-handler="responseHandler"
            data-export-types="['json','csv','xlsx','pdf']" data-mobile-responsive="true">

            <thead>
                <tr>
                    <th data-field="pregunta">Preguntas</th>
                </tr>
            </thead>
            <tbody>
                {{#each preguntas}}
                <tr id="{{id_pregunta}}">
                    <td>{{pregunta}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</main>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function editar(id) {
        window.location.href = `/administrar/encuestas/programar/preguntas/editar/{{{encuesta.id}}}/${id}`;
    };

    function eliminar(id, pregunta) {
        console.log('id:' + id);
        Swal.fire({
            title: "Deseas eliminar el frente politico?",
            html: `${pregunta}`,
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Eliminar",
            cancelButtonText: "Cancelar"
        }).then((result) => {
            if (result.isConfirmed) {
                $.post(`/administrar/encuestas/programar/preguntas/eliminar/{{{encuesta.id}}}/${id}`, // url
                    { 'id': id } // data to be submit
                ).done(function (data) {
                    Swal.fire({
                        title: "Pregunta Eliminada",
                        text: "Se ha eliminado la pregunta correctamente",
                        icon: "success",
                        timer: 10000
                    }).then(() => {
                        window.location.href = `/administrar/encuestas/programar/preguntas/{{{encuesta.id}}}`;
                    });
                }).fail(function () {
                    Swal.fire({
                        title: "Ocurrió un error!",
                        text: "No se pudo eliminar la pregunta.",
                        icon: "error",
                        timer: 10000
                    }).then(() => {
                        window.location.href = '/administrar/encuestas/';
                    });
                });
            }
        });
    };
    function detailFormatter(index, row) {
        var html = '';
        var indexs = 0;
        var data = {};
        $.each(row, function (key, value) {
            var columns = $("th:eq(" + (indexs + 1) + ")").data("field")
            if (columns != undefined) {
                data[columns] = row[columns];
                indexs++;
            }
        });
        html =
            `<div class="card border-primary">
                    <div class="card-footer">
                        <button class=" btn btn-outline-info mx-1" onClick="editar('${row._id}')">
                            <i class="fa fa-fw fa-edit"></i>
                            Editar
                        </button>
                        <button class=" btn btn-outline-primary mx-1" onClick="eliminar('${row._id}', ' ${data.pregunta}')">
                            <i class="fa fa-fw fa-trash"></i>
                            Eliminar
                        </button>
                    </div>
                </div>`
        return html
    }
</script>