<main>
    <div class="container-fluid">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/inicio"><i class="fa fa-fw fa-home"></i>Inicio</a></li>
            <li class="breadcrumb-item"><a href="/administrar"><i class="fa fa-fw fa-cogs"></i>Administrar</a></li>
            <li class="breadcrumb-item"><a href="/administrar/referendos"><i class="fa fa-fw fa-tag"></i>Referendos</a></li>
            <li class="breadcrumb-item"><a href="/administrar/referendos/programar/{{referendo.id}}"><i class="fa fa-fw fa-file-text-o"></i>Programar</a></li>
            <li class="breadcrumb-item active"><i class="fa fa-fw fa-users"></i>Consultados</li>
        </ol>
    </div>
    <div class="container mt-4">
        <h2>Lista de participantes inscritos para el Referéndum</h2>
        <h5>{{referendo.titulo}}</h5>
        <p class="small">{{referendo.descripcion}}</p>
        <a id="back" class="btn btn-dark" href="/administrar/referendos/programar/{{referendo.id}}">
            <i class="fa fa-fw fa-undo"></i> Retornar
        </a>
        <dir class="row">
            <div class="col col-md-6">
                <div id="toolbarUsuarios">
                    <button class=" btn btn-outline-primary mx-1" onClick="llenar('{{referendo.id}}')">
                        <i class="fa fa-fw fa-share-square"></i> Inscribir a todos los usuarios
                    </button>
                </div>
                <table class="table table-condensed text-small" id="table" data-toggle="table" data-locale="es-ES"
                    data-toolbar="#toolbarUsuarios" data-search="true" data-advanced-search="false"
                    data-show-refresh="false" data-show-fullscreen="true" data-detail-view="true"
                    data-detail-formatter="detailFormatterUsuarios" data-show-export="true" data-click-to-select="true"
                    data-sortable="true" data-minimum-count-columns="2" data-show-pagination-switch="false"
                    data-pagination="true" data-id-field="id" data-page-list="[5, 10, 15, 20, all]"
                    data-show-footer="false" data-response-handler="responseHandler"
                    data-export-types="['json','csv','xlsx','pdf']" data-mobile-responsive="true">

                    <thead>
                        <tr>
                            <th data-field="cedula">Cédula de Identidad</th>
                            <th data-field="nombre">Apellidos y Nombres</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each usuarios}}
                        <tr id="{{id}}">
                            <td>{{cedula}}</td>
                            <td>{{nombre}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            <div class="col col-md-6">
                <div id="toolbarConsultados">
                    <button class=" btn btn-outline-primary mx-1" onClick="vaciar('{{referendo.id}}')">
                        <i class="fa fa-fw fa-trash"></i> Vaciar la lista de inscritos
                    </button>
                </div>
                <table class="table table-condensed text-small" id="table" data-toggle="table" data-locale="es-ES"
                    data-toolbar="#toolbarConsultados" data-search="true" data-advanced-search="false"
                    data-show-refresh="false" data-show-fullscreen="true" data-detail-view="true"
                    data-detail-formatter="detailFormatterConsultados" data-show-export="true" data-click-to-select="true"
                    data-sortable="true" data-minimum-count-columns="2" data-show-pagination-switch="false"
                    data-pagination="true" data-id-field="id" data-page-list="[5, 10, 15, 20, all]"
                    data-show-footer="false" data-response-handler="responseHandler"
                    data-export-types="['json','csv','xlsx','pdf']" data-mobile-responsive="true">

                    <thead>
                        <tr>
                            <th data-field="cedula">Cédula de Identidad</th>
                            <th data-field="nombre">Apellidos y Nombres</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each inscritos}}
                        <tr id="{{id_usuario}}">
                            <td>{{cedula}}</td>
                            <td>{{nombre}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </dir>
    </div>
</main>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function llenar(id) {
        Swal.fire({
            title: "Deseas inscribir a todos los usuarios?",
            html: `Se incribiran a todos los usuarios`,
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Confirmar",
            cancelButtonText: "Cancelar"
        }).then((result) => {
            if (result.isConfirmed) {
                $.post(`/administrar/referendos/programar/inscritos/llenar/{{{referendo.id}}}`, // url
                    { 'id': id } // data to be submit
                ).done(function (data) {
                    Swal.fire({
                        title: "Inscripción Realizada",
                        text: "Se ha inscrito a todos los usuarios correctamente",
                        icon: "success",
                        timer: 10000
                    }).then(() => {
                        window.location.href = `/administrar/referendos/programar/inscritos/{{{referendo.id}}}`;
                    });
                }).fail(function () {
                    Swal.fire({
                        title: "Ocurrió un error!",
                        text: "No se pudo realizar la inscripcion.",
                        icon: "error",
                        timer: 10000
                    }).then(() => {
                        window.location.href = '/administrar/referendos/';
                    });
                });
            }
        });
    };
    function vaciar(id) {
        Swal.fire({
            title: "Deseas eliminar a los usuarios inscritos?",
            html: `Se anularan las incripciones de todos los usuarios.`,
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Confirmar",
            cancelButtonText: "Cancelar"
        }).then((result) => {
            if (result.isConfirmed) {
                $.post(`/administrar/referendos/programar/inscritos/vaciar/{{{referendo.id}}}`, // url
                    { 'id': id } // data to be submit
                ).done(function (data) {
                    Swal.fire({
                        title: "Inscripciones Anuladas",
                        text: "Se ha anulado la inscripción de todos los usuarios",
                        icon: "success",
                        timer: 10000
                    }).then(() => {
                        window.location.href = `/administrar/referendos/programar/inscritos/{{{referendo.id}}}`;
                    });
                }).fail(function () {
                    Swal.fire({
                        title: "Ocurrió un error!",
                        text: "No se pudo realizar la anulación de la inscripcion.",
                        icon: "error",
                        timer: 10000
                    }).then(() => {
                        window.location.href = '/administrar/referendos/';
                    });
                });
            }
        });
    };
    function adicionar(id, cedula, nombre) {
        console.log(id, cedula, nombre);
        $.post(`/administrar/referendos/programar/inscritos/adicionar/{{{referendo.id}}}/${id}`, // url
            { 'id': id } // data to be submit
        ).done(function (data) {
            Swal.fire({
                title: "Inscripcion de usuario",
                text: "Se ha inscrito al usuario correctamente",
                icon: "success",
                timer: 10000
            }).then(() => {
                window.location.href = `/administrar/referendos/programar/inscritos/{{{referendo.id}}}`;
            });
        }).fail(function () {
            Swal.fire({
                title: "Ocurrió un error!",
                text: "No se pudo anular la inscripcion.",
                icon: "error",
                timer: 10000
            }).then(() => {
                window.location.href = '/administrar/referendos/programar/{{{referendo.id}}}';
            });
        });
    };
    function eliminar(id, cedula, nombre) {
        console.log('id:' + id);
        Swal.fire({
            title: "Deseas anular inscripcion?",
            html: `<b>${cedula}</b><br>${nombre}`,
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Eliminar",
            cancelButtonText: "Cancelar"
        }).then((result) => {
            if (result.isConfirmed) {
                $.post(`/administrar/referendos/programar/inscritos/eliminar/{{{referendo.id}}}/${id}`, // url
                    { 'id': id } // data to be submit
                ).done(function (data) {
                    Swal.fire({
                        title: "Inscripcion Anulada",
                        text: "Se ha anulado la inscripción correctamente",
                        icon: "success",
                        timer: 10000
                    }).then(() => {
                        window.location.href = `/administrar/referendos/programar/inscritos/{{{referendo.id}}}`;
                    });
                }).fail(function () {
                    Swal.fire({
                        title: "Ocurrió un error!",
                        text: "No se pudo anular la inscripcion.",
                        icon: "error",
                        timer: 10000
                    }).then(() => {
                        window.location.href = '/administrar/referendos/';
                    });
                });
            }
        });
    };
    function detailFormatterConsultados(index, row) {
        var html = '';
        var indexs = 0;
        var data = {};
        $.each(row, function (key, value) {
            var columns = $("th:eq(" + (indexs + 1) + ")").data("field")
            if (columns != undefined) {
                data[columns] = row[columns];
                indexs++;
            }
        });
        html =
            `<div class="card border-primary">
                    <div class="card-footer">
                        <button class=" btn btn-outline-primary mx-1" onClick="eliminar('${row._id}', '${data.cedula}', ' ${data.nombre}')">
                            <i class="fa fa-fw fa-minus-circle"></i>
                            Anular inscripción
                        </button>
                    </div>
                </div>`
        return html
    };
    function detailFormatterUsuarios(index, row) {
        var html = '';
        var indexs = 0;
        var data = {};
        $.each(row, function (key, value) {
            var columns = $("th:eq(" + (indexs + 1) + ")").data("field")
            if (columns != undefined) {
                data[columns] = row[columns];
                indexs++;
            }
        });
        html =
            `<div class="card border-primary">
                    <div class="card-footer">
                        <button class=" btn btn-outline-primary mx-1" onClick="adicionar('${row._id}', '${data.cedula}', ' ${data.nombre}')">
                            <i class="fa fa-fw fa-plus-circle"></i>
                            Inscribir al usuario
                        </button>
                    </div>
                </div>`
        return html
    };
</script>