<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script>
    function onSubmit(event) {
        const response = grecaptcha.getResponse();
        if (response.length === 0) {
            Swal.fire({
                title: "reCAPTCHA",
                text: "Por favor, completa el reCAPTCHA antes de enviar el formulario.",
                icon: "info"
            });
            event.preventDefault(); // Evita el envío del formulario
        }
    }
</script>
<main>
    <div class="container d-flex justify-content-center align-items-center min-vh-100">
        <div class="login-container">
            <div class="avatar">
                <i class="fa fa-envelope" aria-hidden="true"></i>
            </div>
            <h4>Verificar Correo Electrónico</h4>
            <p class="mb-4">Introduce tu correo electrónico.</p>
            <form method="post" action="/verify/email" onsubmit="onSubmit(event)">
                <div class="input-group mb-3">
                    <span class="input-group-text" id="email-addon"><i class="fa fa-envelope" aria-hidden="true"></i></span>
                    <input class="form-control" id="email" name="email" type="email" placeholder="Correo electrónico"
                        required="required" aria-describedby="email-addon" autocomplete="off">
                </div>
                <div class="g-recaptcha" data-sitekey="{{site_key}}"></div>
                <button type="submit" class="btn btn-primary">Verificar Correo Electrónico</button>
            </form>
            <div class="footer-links mt-4">
                <a href="/login">Volver al inicio de sesión</a>
            </div>
        </div>
    </div>
</main>