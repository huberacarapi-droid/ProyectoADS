    <!--Bootstrap JS-->
    <script src="http://cdn.jsdelivr.net/npm/bootstrap@5.0.1/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Bootstrap Table JS -->
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table.min.js"></script>
    <!-- TableExport Plugin JS -->
    <script src="https://unpkg.com/tableexport.jquery.plugin/tableExport.min.js"></script>
    <!-- js-xlsx -->
    <script src="https://unpkg.com/xlsx/dist/xlsx.core.min.js"></script>
    <!-- FileSaver -->
    <script src="https://unpkg.com/file-saver/dist/FileSaver.min.js"></script>
    <!-- jsPDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.3.1/jspdf.umd.min.js"></script>
    <!-- jspdf-autotable -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.13/jspdf.plugin.autotable.min.js"></script>
    <!-- Bootstrap Table Locale Plugin JS -->
    <script src="https://unpkg.com/bootstrap-table@1.18.3/dist/bootstrap-table-locale-all.min.js"></script>
    <!-- Bootstrap Table Export Extension JS -->
    <script
        src="https://unpkg.com/bootstrap-table@1.18.3/dist/extensions/export/bootstrap-table-export.min.js"></script>
    <!-- Moment.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <!-- flatpickr -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        var locale_es = {
            firstDayOfWeek: 1,
            weekdays: {
                shorthand: ['Do', 'Lu', 'Ma', 'Mi', 'Ju', 'Vi', 'Sa'],
                longhand: ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'],
            },
            months: {
                shorthand: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Оct', 'Nov', 'Dic'],
                longhand: ['Enero', 'Febreo', 'Мarzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'],
            }
        }
        
        flatpickr("input[type=date-local]", {
            dateFormat: "Y-m-d",
            minDate: "today",
            locale: locale_es,
        });
        flatpickr("input[type=datetime-local]", {
            enableTime: true,
            dateFormat: "Y-m-d H:i",
            time_24hr: true,
            minDate: "today",
            locale: locale_es,
        });
        
        const fp = flatpickr("input[type=date-birth]", {
            dateFormat: "Y-m-d",
            locale: locale_es,
        });

        var inputs = document.getElementsByClassName("flatpickr-input");
        for (var i = 0; i < inputs.length; i++) {
            inputs[i].readOnly = false;
        }
    </script>
    <!-- Localización personalizada -->
    <script>
        $.extend($.fn.bootstrapTable.defaults, {
            formatExport: function () {
                return 'Exportar datos';
            },
            formatExportData: function (type) {
                switch (type) {
                    case 'json': return 'JSON';
                    case 'xml': return 'XML';
                    case 'csv': return 'CSV';
                    case 'txt': return 'TXT';
                    case 'sql': return 'SQL';
                    case 'excel': return 'MS-Excel (xls)';
                    case 'xlsx': return 'MS-Excel (xlsx)';
                    case 'pdf': return 'PDF';
                    default: return type;
                }
            }
        });
    </script>
